# Mercure hub config (Caddy) — see upstream:
# https://github.com/dunglas/mercure/blob/main/Caddyfile
{
	{$GLOBAL_OPTIONS}
}

{$CADDY_EXTRA_CONFIG}

{$SERVER_NAME:localhost} {
	log {
		format filter {
			fields {
				request>uri query {
					replace authorization REDACTED
				}
			}
		}
	}

	encode zstd gzip

	mercure {
		publisher_jwt {env.MERCURE_PUBLISHER_JWT_KEY} {env.MERCURE_PUBLISHER_JWT_ALG}
		subscriber_jwt {env.MERCURE_SUBSCRIBER_JWT_KEY} {env.MERCURE_SUBSCRIBER_JWT_ALG}

		# Allow browsers to subscribe without a JWT (public updates only).
		anonymous
		cors_origins *
	}

	{$CADDY_SERVER_EXTRA_DIRECTIVES}

	log_skip /robots.txt
	log_skip /healthz
	log_skip /favicon.ico

	header / Content-Type "text/html; charset=utf-8"
	respond / `






Welcome to Mercure



Welcome to Mercure



The URL of your hub is /.well-known/mercure.



Read the documentation on Mercure.rocks, real-time apps made easy.`
	respond /robots.txt `User-agent: *
Disallow: /`
	# Deprecated: use the /mercure/health/ready and /mercure/health/live admin API endpoints for transport-aware health checks
	respond /healthz 200
	respond "Not Found" 404
}
